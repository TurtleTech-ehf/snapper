#: ../../source/reference/formats.rst:4
msgid "Supported Formats"
msgstr "Studd snið"

#: ../../source/reference/formats.rst:6
msgid ""
"``snapper`` classifies text into *prose regions* (reflowed at sentence "
"boundaries) and *structure regions* (passed through unchanged). The "
"classification depends on the format."
msgstr ""
"``snapper`` flokkar texta í *textasvæði* (endurflætt við setningarskil) "
"og *uppbyggingarsvæði* (send í gegn óbreytt). Flokkunin fer eftir sniðinu."

#: ../../source/reference/formats.rst:10
msgid "Org-mode (``--format org``)"
msgstr "Org-mode (``--format org``)"

#: ../../source/reference/formats.rst:13 ../../source/reference/formats.rst:55
#: ../../source/reference/formats.rst:76
msgid "Structure regions (preserved)"
msgstr "Uppbyggingarsvæði (varðveitt)"

#: ../../source/reference/formats.rst:15
msgid "``#+BEGIN_*`` ..."
msgstr "``#+BEGIN_*`` ..."

#: ../../source/reference/formats.rst:17
msgid "``#+END_*`` blocks (source, example, quote, etc.)"
msgstr "``#+END_*`` blokkir (frumkóði, dæmi, tilvitnun, o.fl.)"

#: ../../source/reference/formats.rst:19
msgid "``:PROPERTIES:`` ..."
msgstr "``:PROPERTIES:`` ..."

#: ../../source/reference/formats.rst:21
msgid "``:END:`` drawers"
msgstr "``:END:`` skúffur"

#: ../../source/reference/formats.rst:23
msgid "``#+KEYWORD:`` directives (TITLE, AUTHOR, DATE, OPTIONS, etc.)"
msgstr "``#+KEYWORD:`` lýsiorð (TITLE, AUTHOR, DATE, OPTIONS, o.fl.)"

#: ../../source/reference/formats.rst:25
msgid "Table rows (lines starting with ``|``)"
msgstr "Töflulínur (línur sem byrja á ``|``)"

#: ../../source/reference/formats.rst:27
msgid "Comment lines (starting with ``#`` but not ``#+`` )"
msgstr "Athugasemdarlínur (byrja á ``#`` en ekki ``#+`` )"

#: ../../source/reference/formats.rst:29
msgid "Headline stars and TODO keywords"
msgstr "Fyrirsagnastjörnur og TODO lykilorð"

#: ../../source/reference/formats.rst:31
msgid "List item markers (``-``, ``+``, ``1.``)"
msgstr "Listaatriðamerki (``-``, ``+``, ``1.``)"

#: ../../source/reference/formats.rst:34 ../../source/reference/formats.rst:68
#: ../../source/reference/formats.rst:87
msgid "Prose regions (reflowed)"
msgstr "Textasvæði (endurflætt)"

#: ../../source/reference/formats.rst:36 ../../source/reference/formats.rst:89
msgid "Paragraph text"
msgstr "Málsgreinatexti"

#: ../../source/reference/formats.rst:38
msgid "Headline text (after the stars and keyword)"
msgstr "Fyrirsagnartexti (á eftir stjörnunum og lykilorðinu)"

#: ../../source/reference/formats.rst:40 ../../source/reference/formats.rst:93
msgid "List item text (after the marker)"
msgstr "Texti listaatriðis (á eftir merkinu)"

#: ../../source/reference/formats.rst:43
msgid "Inline tokens (kept atomic)"
msgstr "Innleidd tákn (haldin óbrotin)"

#: ../../source/reference/formats.rst:45
msgid "These tokens within prose are not split across lines:"
msgstr "Þessum táknum innan texta er ekki skipt á milli lína:"

#: ../../source/reference/formats.rst:47
msgid "Links: ``[[url][description]]``"
msgstr "Tenglar: ``[[url][description]]``"

#: ../../source/reference/formats.rst:49
msgid "Inline code: ``~code~``, ``==verbatim==``"
msgstr "Innleiður kóði: ``~code~``, ``==verbatim==``"

#: ../../source/reference/formats.rst:52
msgid "LaTeX (``--format latex``)"
msgstr "LaTeX (``--format latex``)"

#: ../../source/reference/formats.rst:57
#, python-brace-format
msgid "Preamble (everything before ``\\begin{document}``)"
msgstr "Formáli (allt á undan ``\\begin{document}``)"

#: ../../source/reference/formats.rst:59
msgid ""
"Non-prose environments: equation, align, figure, table, tabular, "
"lstlisting, verbatim, minted, tikzpicture, and their starred variants"
msgstr ""
"Umhverfi sem eru ekki texti: equation, align, figure, table, tabular, "
"lstlisting, verbatim, minted, tikzpicture, og stjörnumerktar afbrigði þeirra"

#: ../../source/reference/formats.rst:61
msgid "Display math: ``\\[...\\]``"
msgstr "Sýnistærðfræði: ``\\[...\\]``"

#: ../../source/reference/formats.rst:63
msgid "Comment lines (starting with ``%``)"
msgstr "Athugasemdarlínur (byrja á ``%``)"

#: ../../source/reference/formats.rst:65
#, python-brace-format
msgid "``\\end{document}``"
msgstr "``\\end{document}``"

#: ../../source/reference/formats.rst:70
msgid "Body text between structural elements"
msgstr "Meginmálstexti á milli uppbyggingareininga"

#: ../../source/reference/formats.rst:73
msgid "Markdown (``--format markdown``)"
msgstr "Markdown (``--format markdown``)"

#: ../../source/reference/formats.rst:78
msgid "Fenced code blocks (``````` or ``~~~``)"
msgstr "Afgirtar kóðablokkir (``````` eða ``~~~``)"

#: ../../source/reference/formats.rst:80
msgid "Front matter (``---`` or ``+++``  delimited at file start)"
msgstr "Framefni (``---`` eða ``+++`` afmarkað í byrjun skráar)"

#: ../../source/reference/formats.rst:82
msgid "Heading markers (``#``, ``##``, etc.)"
msgstr "Fyrirsagnarmerki (``#``, ``##``, o.fl.)"

#: ../../source/reference/formats.rst:84
msgid "List item markers (``-``, ``\\*``, ``+``, ``1.``)"
msgstr "Listaatriðamerki (``-``, ``\\*``, ``+``, ``1.``)"

#: ../../source/reference/formats.rst:91
msgid "Heading text (after the marker)"
msgstr "Fyrirsagnartexti (á eftir merkinu)"

#: ../../source/reference/formats.rst:96
msgid "Plaintext (``--format plaintext``)"
msgstr "Ósniðinn texti (``--format plaintext``)"

#: ../../source/reference/formats.rst:98
msgid "Everything is prose. Blank lines are preserved as paragraph separators."
msgstr "Allt er texti. Auðar línur eru varðveittar sem málsgreinaskil."

#: ../../source/reference/formats.rst:102
msgid "Sentence Detection"
msgstr "Setningargreining"

#: ../../source/reference/formats.rst:104
msgid ""
"``snapper`` uses Unicode UAX #29 sentence boundary detection as a "
"baseline, then merges false splits caused by known abbreviations:"
msgstr ""
"``snapper`` notar Unicode UAX #29 setningarmarkaskil sem grunn og sameinar "
"síðan rangar skiptingar sem stafa af þekktum skammstöfunum:"

