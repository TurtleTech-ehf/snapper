{
  "name": "snapper",
  "displayName": "snapper - Semantic Line Breaks",
  "description": "Format prose with semantic line breaks for clean git diffs",
  "version": "0.7.4",
  "publisher": "TurtleTech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TurtleTech-ehf/snapper"
  },
  "homepage": "https://snapper.turtletech.us",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "semantic",
    "line breaks",
    "latex",
    "orgmode",
    "markdown",
    "academic",
    "formatter"
  ],
  "activationEvents": [
    "onLanguage:org",
    "onLanguage:latex",
    "onLanguage:markdown",
    "onLanguage:plaintext",
    "onLanguage:restructuredtext"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "snapper.formatDocument",
        "title": "Format Document with snapper",
        "category": "snapper"
      },
      {
        "command": "snapper.restartServer",
        "title": "Restart Language Server",
        "category": "snapper"
      },
      {
        "command": "snapper.showOutputChannel",
        "title": "Show Output",
        "category": "snapper"
      },
      {
        "command": "snapper.initProject",
        "title": "Initialize Project (.snapperrc.toml)",
        "category": "snapper"
      },
      {
        "command": "snapper.checkFile",
        "title": "Check Current File",
        "category": "snapper"
      },
      {
        "command": "snapper.showDiff",
        "title": "Preview Formatting Changes",
        "category": "snapper"
      }
    ],
    "configuration": {
      "title": "snapper",
      "properties": {
        "snapper.path": {
          "type": "string",
          "default": "snapper",
          "description": "Path to the snapper binary"
        },
        "snapper.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the snapper language server"
        }
      }
    },
    "keybindings": [
      {
        "command": "snapper.formatDocument",
        "key": "shift+alt+f",
        "when": "resourceLangId == 'markdown' || resourceLangId == 'org' || resourceLangId == 'latex' || resourceLangId == 'plaintext' || resourceLangId == 'restructuredtext'"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0",
    "vscode-languageclient": "^9.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
